          "name": "Twilio Look up a Phone Number",
          "request": {
            "name": "Twilio Look up a Phone Number",
            "description": {
              "content": "Query information about a phone number. Specify which data packages to include using the Fields parameter. Available packages include validation, line type intelligence, caller name, SIM swap, identity match, SMS pumping risk, and more.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "PhoneNumbers",
                ":PhoneNumber"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "Fields",
                  "value": "<string>",
                  "description": "Comma-separated list of data packages to return. Available fields include validation, line_type_intelligence, caller_name, sim_swap, identity_match, sms_pumping_risk, phone_number_quality_score, reassigned_number, line_status"
                },
                {
                  "disabled": false,
                  "key": "CountryCode",
                  "value": "<string>",
                  "description": "ISO 3166-1 alpha-2 country code for national format numbers"
                },
                {
                  "disabled": false,
                  "key": "FirstName",
                  "value": "<string>",
                  "description": "First name for identity match"
                },
                {
                  "disabled": false,
                  "key": "LastName",
                  "value": "<string>",
                  "description": "Last name for identity match"
                },
                {
                  "disabled": false,
                  "key": "AddressLine1",
                  "value": "<string>",
                  "description": "Address line 1 for identity match"
                },
                {
                  "disabled": false,
                  "key": "AddressLine2",
                  "value": "<string>",
                  "description": "Address line 2 for identity match"
                },
                {
                  "disabled": false,
                  "key": "City",
                  "value": "<string>",
                  "description": "City for identity match"
                },
                {
                  "disabled": false,
                  "key": "State",
                  "value": "<string>",
                  "description": "State or province for identity match"
                },
                {
                  "disabled": false,
                  "key": "PostalCode",
                  "value": "<string>",
                  "description": "Postal code for identity match"
                },
                {
                  "disabled": false,
                  "key": "AddressCountryCode",
                  "value": "<string>",
                  "description": "ISO country code for identity match address"
                },
                {
                  "disabled": false,
                  "key": "NationalId",
                  "value": "<string>",
                  "description": "National ID for identity match"
                },
                {
                  "disabled": false,
                  "key": "DateOfBirth",
                  "value": "<string>",
                  "description": "Date of birth for identity match (YYYYMMDD)"
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "PhoneNumber",
                  "description": "(Required) Phone number to look up in E.164 format"
                }
              ]
            },
            "header": [
